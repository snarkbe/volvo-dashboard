VOLVO_VIN=your-vin
VCC_API_KEY=your-vcc-primary-api-key
VOLVO_CLIENT_ID=your-oauth-client-id
VOLVO_CLIENT_SECRET=your-oauth-client-secret
VOLVO_REDIRECT_URI=http://localhost:4000/callback
# VOLVO_TOKEN_FILE defaults to /data/token.json inside the container.
# Only set it when running authorize on the host:
#   VOLVO_TOKEN_FILE=./data/token.json
